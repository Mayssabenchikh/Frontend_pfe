VITE_KEYCLOAK_URL=http://localhost:8081/
VITE_KEYCLOAK_REALM=skillify
VITE_KEYCLOAK_CLIENT=skillify-web
# Backend API : laisser vide en dev pour utiliser le proxy Vite (/api → 8080) et éviter CORS (localhost vs 127.0.0.1).
# Pour forcer les appels directs : VITE_API_URL=http://localhost:8080
VITE_API_URL=
VITE_COMPETENCE_QUIZ_API_URL=http://127.0.0.1:8002
# En dev, localhost:5173 → 127.0.0.1:8003 = CORS ; le code utilise le proxy /matching-api même si cette ligne existe.
# VITE_MATCHING_DIRECT=1 pour forcer l’URL directe ci-dessous.
VITE_MATCHING_API_URL=http://127.0.0.1:8003