# Spring Boot API (JWT via Keycloak)
VITE_API_URL=http://localhost:8080

# FastAPI competence quiz (optional)
VITE_COMPETENCE_QUIZ_API_URL=http://127.0.0.1:8002

# Microservice correspondances (FastAPI)
# En dev, même avec VITE_MATCHING_API_URL=http://127.0.0.1:8003, le front utilise le proxy `/matching-api`
# (évite CORS). Optionnel : VITE_MATCHING_DIRECT=1 pour appeler l’URL directe + CORS côté FastAPI.
# VITE_MATCHING_API_URL=https://matching.example.com
# VITE_MATCHING_INTERNAL_API_KEY=
# VITE_MATCHING_PROXY_TARGET=http://127.0.0.1:8003
